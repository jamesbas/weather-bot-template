# =============================================================================
# Weather Bot Template — .env.example
# Copy to .env and fill with real values. NEVER commit .env.
# =============================================================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=                              # your numeric user ID
TELEGRAM_APPROVER_IDS=                         # comma-separated approver user IDs

# --- Gmail (SMTP send + IMAP poll) ---
GMAIL_SMTP_USER=yourbrandweatherbot@gmail.com
GMAIL_APP_PASSWORD=                            # 16-char Google App Password
GMAIL_APPROVAL_RECIPIENTS=you@example.com,coforecaster@example.com
SOUNDING_EMAIL_ALLOWED_SENDERS=you@example.com,coforecaster@example.com
FORECASTER_BRIEFING_EMAIL_RECIPIENTS=you@example.com,coforecaster@example.com
CHASE_TARGET_EMAIL_RECIPIENTS=you@example.com,coforecaster@example.com

# --- Facebook (optional) ---
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_GRAPH_API_VERSION=v24.0

# --- MarineCast (skip if inland) ---
MARINECAST_APPROVAL_RECIPIENTS=you@example.com,coforecaster@example.com
MARINECAST_APPROVAL_EXPIRES_HOURS=6
# Set to 1 to switch MarineCast from approval-gated to auto-publish + FYI mode.
# See SETUP_GUIDE.md §13.11.
MARINECAST_AUTO_PUBLISH=

# --- GrowCast ---
# Set to 1 to switch the public daily GrowCast from approval-gated to
# auto-publish + FYI mode. The weekly PRIVATE grower briefing is always
# email-only and is unaffected. See SETUP_GUIDE.md §13.11.
GROWCAST_PUBLIC_AUTO_PUBLISH=
GROWCAST_PRIVATE_RECIPIENTS=you@example.com,coforecaster@example.com

# --- Tropical Watch (skip if landlocked / non-coastal) ---
TROPICAL_WATCH_APPROVAL_RECIPIENTS=you@example.com,coforecaster@example.com
TROPICAL_WATCH_APPROVAL_EXPIRES_HOURS=12

# --- Region settings ---
WX_REGION_NAME=Delmarva
WX_NWS_OFFICES=PHI,AKQ                         # 3-letter office codes
WX_STATE_CODES=DE,MD,VA                        # alert filtering
WX_FORECAST_POINTS=Lewes:38.7783,-75.1394;Dover:39.1582,-75.5244;Salisbury:38.3607,-75.5994
WX_TIMEZONE=America/New_York

# --- Per-bot tunables ---
ALERT_EXPLAINER_DEDUP_TTL_HOURS=12

# --- Optional: second publish target (your own website) ---
# If set, approved content posts to your website in parallel with Facebook
# via an HMAC-signed POST. See SETUP_GUIDE.md §13.6. Leave blank to skip.
WEBSITE_BASE_URL=
WEBSITE_API_KEY=
WEBSITE_HMAC_SECRET=
WEBSITE_DISABLED=                              # set to 1 to kill-switch without code change

# --- Optional: Event Weather Advisor (per-customer paid workflow) ---
# Only needed if you build the Event Weather Advisor bot. See §13.7.
EVENT_WEATHER_INTERNAL_RECIPIENTS=you@example.com,coforecaster@example.com
EVENT_WEATHER_DEFAULT_TIMEZONE=America/New_York
# Optional Gmail label / filter for event-intake polling (see §13.12).
EVENT_WEATHER_INTAKE_LABEL=

# --- Optional: HREF × SPC × HRRR Synthesis internal briefing ---
# Only needed if you run the private severe-weather synthesis bot. See §10.11.
HREF_SYNTHESIS_EMAIL_RECIPIENTS=you@example.com,coforecaster@example.com
HREF_SYNTHESIS_TELEGRAM_CHAT_ID=
# Set to 1 to disable the HRRR cross-check independently of the HREF run.
HREF_DISABLE_HRRR_CROSSCHECK=
